# Copy to .env and edit. compose reads this via env_file + ${VAR} substitution.

# --- Image / build knobs ---
# Bare EL9 base. Dockerfile.runtime installs Node 20 itself from the EL9
# AppStream module, so the base image does NOT need Node preinstalled.
# Lab (AlmaLinux 9):
#   RUNTIME_BASE_IMAGE=almalinux:9
# On-prem (RHEL UBI 9 — already mirrored on-prem):
#   RUNTIME_BASE_IMAGE=registry.onprem.example.com/ubi9/ubi:latest
RUNTIME_BASE_IMAGE=almalinux:9

# Lightdash docker tag — must match a published GitHub release on $GH_REPO.
# Pinned to 0.2540.0: highest version whose native deps (duckdb, lz4) work on
# EL9 glibc 2.34 / GLIBCXX_3.4.29 with Node 20. Newer versions need GLIBCXX_3.4.30+.
LIGHTDASH_VERSION=0.2540.0

# GitHub release base URL. Defaults to kingfadzi/lightdash-el9.
RELEASE_BASE_URL=https://github.com/kingfadzi/lightdash-el9/releases/download

# Optional npm registry override (used at image-build time to install pnpm).
# Lab leaves blank → registry.npmjs.org. On-prem: point at your internal
# Nexus pull-through proxy so the build does not depend on public npm.
# NPM_REGISTRY=https://nexus.onprem.example.com/repository/npm-public/
NPM_REGISTRY=

# Optional proxy (leave blank for direct internet).
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# --- Lightdash core config ---
# Public URL the app is served from. Lightdash uses this in emails / links.
SITE_URL=http://localhost:8080
PORT=8080
NODE_ENV=production

# Used for cookie/session signing. Generate with: openssl rand -hex 32
LIGHTDASH_SECRET=replace-me-with-a-long-random-string

# --- Lightdash metadata Postgres (its OWN state DB, not the data warehouse) ---
PGHOST=helios.butterflycluster.com
PGPORT=5432
PGDATABASE=lightdash
PGUSER=postgres
PGPASSWORD=postgres
